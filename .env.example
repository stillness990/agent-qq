# OneBot v11 WebSocket 地址，由 NapCat 提供
# 常见格式：ws://127.0.0.1:3001 或 ws://host.docker.internal:3001
ONEBOT_WS_URL=ws://host.docker.internal:3001

# OneBot access_token；如果 NapCat 没配置 token 可留空
ONEBOT_ACCESS_TOKEN=

# 只响应私聊消息
ENABLE_PRIVATE_CHAT=true

# 管理员 QQ 号，多个用逗号分隔。/shell、/code 等高风险命令只允许管理员使用
ADMIN_QQ_IDS=

# Claude Code CLI 命令
CLAUDE_CLI_COMMAND=claude

# Claude Code 每次执行超时时间，秒
CLAUDE_TIMEOUT_SECONDS=180

# Claude Code 工作目录。建议限制在项目目录或专用工作区
CLAUDE_WORKDIR=/workspace

# 是否允许管理员使用 /shell 命令
ENABLE_SHELL_COMMAND=true

# /shell 白名单命令前缀，多个用逗号分隔
SHELL_ALLOWED_PREFIXES=pwd,ls,cat,grep,find,git status,python --version,python3 --version,df -h,free -h,whoami,uname -a

# 消息去重缓存 TTL，秒
MESSAGE_DEDUPE_TTL_SECONDS=300

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# NapCat / OneBot 自动重连配置
RECONNECT_INITIAL_SECONDS=2
RECONNECT_MAX_SECONDS=60

# 单条 QQ 回复最大长度，超过会分段发送
QQ_REPLY_CHUNK_SIZE=1800

# 宿主机 Claude Code 配置目录，Docker Compose 会挂载到容器 /root/.claude
CLAUDE_CONFIG_DIR=/path/to/.claude
